# ─── Supabase (required) ──────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── App URL (required) ───────────────────────────────────────────────────────
# Your production domain — used for Supabase auth redirect URLs
# Also add this to Supabase → Auth → URL Configuration → Site URL
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ─── Dev only (remove or leave empty in production) ───────────────────────────
# Enables the "Dev Bypass" quick-login button on the login page.
# Only works when NODE_ENV=development — safe to leave false in production.
NEXT_PUBLIC_ENABLE_DEV_BYPASS=false
NEXT_PUBLIC_DEV_BYPASS_EMAIL=
NEXT_PUBLIC_DEV_BYPASS_PASSWORD=
